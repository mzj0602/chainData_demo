# Alchemy Sepolia RPC（用于 Ethers.js 读链）
VITE_ALCHEMY_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Etherscan API Key（用于 Etherscan API 读取交易）
VITE_ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# DataLogger 合约地址（部署后填入）
VITE_CONTRACT_ADDRESS=0x...

# The Graph Subgraph GraphQL Endpoint（部署 Subgraph 后填入）
VITE_GRAPH_URL=https://api.studio.thegraph.com/query/YOUR_ID/data-logger/v0.0.1
